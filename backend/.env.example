SPK_ENVIRONMENT=development
SPK_APP_NAME=SPK Ertis Corporate HR API
SPK_API_PREFIX=/api/v1
SPK_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/spk_hr
SPK_DATABASE_ECHO=false
SPK_SENSITIVE_DATA_KEY=
SPK_LOG_LEVEL=INFO
SPK_DEV_AUTH_ENABLED=true
SPK_DEV_DEFAULT_USER=admin
SPK_OIDC_ISSUER=
SPK_OIDC_AUDIENCE=
SPK_OIDC_JWKS_URL=
SPK_CORS_ORIGINS=http://localhost:5173
SPK_DOCUMENT_STORAGE_BACKEND=local
SPK_DOCUMENT_STORAGE_ROOT=.spk-documents
SPK_DOCUMENT_MAX_SIZE_BYTES=20971520
SPK_DOCUMENT_ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png
SPK_S3_ENDPOINT_URL=
SPK_S3_BUCKET=
SPK_S3_ACCESS_KEY=
SPK_S3_SECRET_KEY=
SPK_S3_REGION=us-east-1
